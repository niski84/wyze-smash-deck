# Copy to `.env` and fill in values (`.env` is gitignored).
# cp .env.example .env

# --- Wyze Feral Smash Deck (Open API: https://developer.wyze.com) ---
WYZE_KEY_ID=
WYZE_API_KEY=
# Optional: override port (default 8082)
# WYZE_FERAL_PORT=8082
# PORT=8082

# --- Plex (if you use task server / tooling that reads these) ---
PLEX_LOGIN=
PLEX_PASSWORD=
PLEX_BASE_URL=
PLEX_CLIENT_IDENTIFIER=
PLEX_PRODUCT=
PLEX_VERSION=
PLEX_TOKEN=
PLEX_TARGET_CLIENT_NAME=

# --- TMDB discovery ---
TMDB_API_KEY=
TMDB_READ_ACCESS_TOKEN=
